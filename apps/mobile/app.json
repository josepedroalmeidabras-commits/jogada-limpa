{
  "expo": {
    "name": "Jogada Limpa",
    "slug": "jogada-limpa",
    "scheme": "jogadalimpa",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.jogadalimpa.app",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Para escolheres uma foto de perfil ou escudo da equipa.",
        "NSCalendarsUsageDescription": "Para adicionares jogos confirmados ao teu calendário."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.jogadalimpa.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Para escolheres uma foto de perfil ou escudo da equipa."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#ffffff"
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "Para adicionares jogos confirmados ao teu calendário."
        }
      ]
    ],
    "notification": {
      "iosDisplayInForeground": true
    }
  }
}
