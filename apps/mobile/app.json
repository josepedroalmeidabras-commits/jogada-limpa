{
  "expo": {
    "name": "S7VN",
    "slug": "jogada-limpa",
    "scheme": "s7vn",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0E1812"
    },
    "androidStatusBar": {
      "backgroundColor": "#0E1812",
      "barStyle": "light-content"
    },
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.s7vn.app",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Para escolheres uma foto de perfil ou escudo da equipa.",
        "NSCalendarsUsageDescription": "Para adicionares jogos confirmados ao teu calendário.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0E1812"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.s7vn.app",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Para escolheres uma foto de perfil ou escudo da equipa."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#ffffff"
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "Para adicionares jogos confirmados ao teu calendário."
        }
      ]
    ],
    "notification": {
      "iosDisplayInForeground": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "be854912-d087-4dc1-8736-529380056fa0"
      }
    },
    "owner": "josepedrodev"
  }
}
